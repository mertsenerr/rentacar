# Auto-detect text files and normalize line endings to LF in the repo.
# Working tree retains the platform-native EOL via core.autocrlf.
* text=auto

# Explicit text formats — store as LF
*.cs       text eol=lf
*.csproj   text eol=lf
*.sln      text eol=crlf
*.json     text eol=lf
*.md       text eol=lf
*.html     text eol=lf
*.scss     text eol=lf
*.css      text eol=lf
*.ts       text eol=lf
*.js       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
Dockerfile text eol=lf

# Binary assets — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.svg  text eol=lf
*.pdf  binary
*.zip  binary
*.gltf binary
*.bin  binary
*.bson binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
